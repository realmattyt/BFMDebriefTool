{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f build_standalone.py ] && python3 build_standalone.py >/dev/null 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Rebuilding standalone..."
          }
        ]
      }
    ]
  }
}
